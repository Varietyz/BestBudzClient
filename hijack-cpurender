            // Draw to provided Graphics2D
            g.drawImage(gpuImage, x, y, null);
            return;
        }

        // Original CPU implementation
        originalDrawGraphics(x, g, y);
    }

    private void copyGPUTextureToImage() {
        // Get GPU texture data and copy to BufferedImage
        int gpuTexture = DrawingArea.getGPUTexture();
        if (gpuTexture > 0) {
            // GPU texture → canvasRaster → BufferedImage
            DrawingArea.syncGPUToCPU(); // This updates canvasRaster
            gpuImage.getRaster().setDataElements(0, 0, canvasWidth, canvasHeight, canvasRaster);
        }
    }

