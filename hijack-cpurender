            // Link raster to GPU image
            DataBufferInt buffer = (DataBufferInt) gpuImage.getRaster().getDataBuffer();
            canvasRaster = buffer.getData();
        }
    }

    // IDENTICAL method signature
    public void initDrawingArea() {
        if (GPURenderingEngine.isGPUEnabled()) {
            DrawingArea.initDrawingArea(canvasHeight, canvasWidth, canvasRaster, depthBuffer);
