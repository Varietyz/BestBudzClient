package com.bestbudz.engine.gpu;

import org.lwjgl.opengl.GL11;
import org.lwjgl.opengl.GL20;
import org.lwjgl.opengl.GL30;

public class GPUShaders {
    private static int rectangleProgram;
    private static int circleProgram;
    private static int quadVAO;

    public static void initialize() {
        createQuad();
        rectangleProgram = createShaderProgram(VERTEX_SHADER, RECTANGLE_FRAGMENT);
        circleProgram = createShaderProgram(VERTEX_SHADER, CIRCLE_FRAGMENT);
    }

    public static void drawRectangle(int x, int y, int width, int height, int color) {
        GL20.glUseProgram(rectangleProgram);
        setColorUniforms(rectangleProgram, color);
        setPositionUniforms(rectangleProgram, x, y, width, height);

        GL30.glBindVertexArray(quadVAO);
        GL11.glDrawElements(GL11.GL_TRIANGLES, 6, GL11.GL_UNSIGNED_INT, 0);
    }

    public static void drawRectangleAlpha(int x, int y, int width, int height, int color, int alpha) {
        GL11.glEnable(GL11.GL_BLEND);
        GL11.glBlendFunc(GL11.GL_SRC_ALPHA, GL11.GL_ONE_MINUS_SRC_ALPHA);

        GL20.glUseProgram(rectangleProgram);
        setColorUniformsWithAlpha(rectangleProgram, color, alpha);
        setPositionUniforms(rectangleProgram, x, y, width, height);

        GL30.glBindVertexArray(quadVAO);
        GL11.glDrawElements(GL11.GL_TRIANGLES, 6, GL11.GL_UNSIGNED_INT, 0);

        GL11.glDisable(GL11.GL_BLEND);
    }

    public static void drawCircle(int x, int y, int radius, int color) {
        GL20.glUseProgram(circleProgram);
        setColorUniforms(circleProgram, color);
        GL20.glUniform2f(GL20.glGetUniformLocation(circleProgram, "center"), x, y);
        GL20.glUniform1f(GL20.glGetUniformLocation(circleProgram, "radius"), radius);

        GL30.glBindVertexArray(quadVAO);
        GL11.glDrawElements(GL11.GL_TRIANGLES, 6, GL11.GL_UNSIGNED_INT, 0);
    }

    // Helper methods and shader source code...
    private static final String VERTEX_SHADER = """
        #version 330 core
        layout (location = 0) in vec2 aPos;
        uniform vec2 position;
        uniform vec2 size;
        uniform vec2 screenSize;

        void main() {
            vec2 scaledPos = aPos * size + position;
            vec2 normalizedPos = (scaledPos / screenSize) * 2.0 - 1.0;
            normalizedPos.y = -normalizedPos.y;
            gl_Position = vec4(normalizedPos, 0.0, 1.0);
        }
        """;

    private static final String RECTANGLE_FRAGMENT = """
        #version 330 core
        out vec4 FragColor;
        uniform vec4 color;

        void main() {
            FragColor = color;
        }
        """;

    private static final String CIRCLE_FRAGMENT = """
        #version 330 core
        out vec4 FragColor;
        uniform vec4 color;
        uniform vec2 center;
        uniform float radius;

        void main() {
            float dist = distance(gl_FragCoord.xy, center);
            if (dist > radius) discard;
            FragColor = color;
        }
        """;
}
