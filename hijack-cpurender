            if (j < topY) { i -= topY - j; j = topY; }
            if (k + i1 > bottomX) i1 = bottomX - k;
            if (j + i > bottomY) i = bottomY - j;

            // GPU draw
            GL30.glBindFramebuffer(GL30.GL_FRAMEBUFFER, framebuffer);
            GPUShaders.drawRectangle(k, j, i1, i, l);
