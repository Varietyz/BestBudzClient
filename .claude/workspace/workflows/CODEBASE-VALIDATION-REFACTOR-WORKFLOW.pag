    ]

    SET agent_3.validation_gates = [
        "Base classes implement required methods",
        "Settings integration complete",
        "Semantic guarantees documented",
        "npm run verify-codebase passes"
    ]

    APPEND agent_3 TO agent_sequence

## Task 2.4: Agent 4 - Implementation Migrator

    DECLARE agent_4: object
    SET agent_4.agent_name = "implementation-migrator"
    SET agent_4.agent_type = "general-purpose"
    SET agent_4.agent_phase = 4
    SET agent_4.agent_purpose = "Migrate concrete scanners, validators, and fixers to new base class patterns"
