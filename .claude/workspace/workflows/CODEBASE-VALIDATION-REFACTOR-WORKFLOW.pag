        ✅ agent_focus_points specify algorithm_requirements
        ✅ output_artifacts mapped TO core_documents
        ✅ validation_gates include npm_verification

# PHASE 3: Handoff Protocol Definition

## Task 3.1: Create Handoff Signal Format

    DECLARE handoff_signal_format: object

    SET handoff_signal_format = {
        "agent_completed": "{AGENT_NAME}",
        "phase_status": "complete",
        "artifacts_location": ".claude/workspace/refactor-validation",
        "next_agent": "{NEXT_AGENT_NAME}",
        "handoff_context": {
            "key_findings": [],
            "files_modified": [],
            "settings_keys_added": [],
            "validation_gates_passed": true,
            "npm_verify_status": "pass|fail"
        },
        "orchestrator_action": "ACTIVATE_NEXT_AGENT"
    }

## Task 3.2: Define Settings Integration Handoff

    DECLARE settings_handoff: object

    SET settings_handoff.new_keys = [
        "rules.tooling.autoFix.createBackups: boolean (default: true)",
        "rules.tooling.autoFix.backupLocation: string (default: '.backup')",
        "rules.tooling.autoFix.maxRollbackHistory: number (default: 10)",
        "rules.tooling.autoFix.safetyValidation: boolean (default: true)",
        "rules.severity.halt.critical: boolean (default: true)",
        "rules.severity.halt.high: boolean (default: false)",
        "rules.scanning.createSnapshot: boolean (default: true)"
    ]

    SET settings_handoff.accessors_needed = [
        "getAutoFixBackupSettings()",
        "getSeverityHaltSettings()",
        "getScannerSnapshotSettings()"
    ]

    VALIDATION GATE:
        ✅ handoff_signal_format defined
        ✅ settings_handoff keys documented
        ✅ accessor functions identified

# PHASE 4: Workflow Coordination Algorithm

    DECLARE coordination_sequence: array

## Task 4.1: Pre-Creation Step

    APPEND "ORCHESTRATOR: Pre-create documents in .claude/workspace/refactor-validation/" TO coordination_sequence

    FOR EACH document IN core_documents:
        SET purpose = document_purpose_map[document]
        APPEND " ↓ CREATE " + document + " (purpose: " + purpose + ")" TO coordination_sequence

    APPEND " ↓" TO coordination_sequence
    APPEND "ORCHESTRATOR: EXECUTE Task tool WITH:" TO coordination_sequence
    APPEND "   subagent_type: 'code-tracer-agent'" TO coordination_sequence
    APPEND "   prompt: Architecture analysis for algorithm compliance" TO coordination_sequence
    APPEND " ↓" TO coordination_sequence

## Task 4.2: Agent Sequence Execution

    FOR EACH index FROM 1 TO agent_count:
        SET agent = agent_sequence[index]
        SET next_agent = agent_sequence[index + 1]

        APPEND "PHASE " + index + ": " + agent.agent_name TO coordination_sequence
        APPEND "   PURPOSE: " + agent.agent_purpose TO coordination_sequence
        APPEND "   ALGORITHM: " + algorithm_mappings[agent.component_type] TO coordination_sequence
        APPEND "   ↓ READ all core documents" TO coordination_sequence
        APPEND "   ↓ EXECUTE phase-specific analysis/implementation" TO coordination_sequence
        APPEND "   ↓ UPDATE documents with findings" TO coordination_sequence
        APPEND "   ↓ RUN npm run verify-codebase" TO coordination_sequence
        APPEND "   ↓ SIGNAL completion to orchestrator" TO coordination_sequence
        APPEND "   ↓" TO coordination_sequence

        IF index < agent_count:
            APPEND "ORCHESTRATOR: EXECUTE Task tool WITH:" TO coordination_sequence
            APPEND "   subagent_type: '" + next_agent.agent_type + "'" TO coordination_sequence
            APPEND "   prompt: Continue from Phase " + index + " findings" TO coordination_sequence
            APPEND "   ↓" TO coordination_sequence

    APPEND "ORCHESTRATOR: Workflow complete" TO coordination_sequence
    APPEND " ↓ WORKFLOW-STATE.md: 100% complete" TO coordination_sequence
    APPEND " ↓ All base classes algorithm-compliant" TO coordination_sequence
    APPEND " ↓ All implementations migrated" TO coordination_sequence
    APPEND " ↓ Settings fully configurable" TO coordination_sequence

    VALIDATION GATE:
        ✅ coordination_sequence complete
        ✅ npm_verification included IN each_phase
        ✅ settings_integration tracked

# PHASE 5: Implementation Specifications

## Task 5.1: BaseAutoFixer State-Snapshot-Recovery Implementation

    DECLARE auto_fixer_spec: object

    SET auto_fixer_spec.algorithm = "State-Snapshot-Recovery-Protocol"
    SET auto_fixer_spec.verb_chain = "EXTRACT<Current-State> → CREATE<Checkpoint-Snapshot> → ANALYZE<State-Integrity> → WRITE<Checkpoint-Storage>"

    SET auto_fixer_spec.methods = {
        "extractCurrentState": {
            "signature": "async extractCurrentState(filePath)",
            "returns": "{ path, content, stats, timestamp }",
            "semantic_guarantee": "Non-destructive read; file unmodified",
            "settings_key": null
        },
        "createCheckpointSnapshot": {
            "signature": "async createCheckpointSnapshot(state)",
            "returns": "snapshotId",
            "semantic_guarantee": "Deterministic creation; frozen state artifact",
            "settings_key": "rules.tooling.autoFix.createBackups"
        },
        "analyzeStateIntegrity": {
            "signature": "analyzeStateIntegrity(fixPlan, originalState)",
            "returns": "{ valid: boolean, reason?: string }",
            "semantic_guarantee": "Evaluation check; non-modifying validation",
            "settings_key": "rules.tooling.autoFix.safetyValidation"
        },
        "writeWithRollback": {
            "signature": "async writeWithRollback(fixedContent, snapshotId)",
            "returns": "{ success: boolean, rolledBack?: boolean }",
            "semantic_guarantee": "Atomic write; rollback on failure",
            "settings_key": "rules.tooling.autoFix.createBackups"
        },
        "rollbackFromSnapshot": {
            "signature": "async rollbackFromSnapshot(snapshotId)",
            "returns": "void",
            "semantic_guarantee": "Restores original state exactly",
            "settings_key": null
        }
    }

## Task 5.2: BaseScanner Perceptual-Loop Implementation

    DECLARE scanner_spec: object

    SET scanner_spec.algorithm = "Perceptual-Loop"
    SET scanner_spec.verb_chain = "FIND<Target-Files> → ANALYZE<Content-Patterns> → WRITE<Registry-Output> → REPORT<Summary>"

    SET scanner_spec.methods = {
        "findTargetFiles": {
            "signature": "async findTargetFiles()",
            "returns": "string[]",
            "semantic_guarantee": "Boolean existence check; non-invasive",
            "settings_key": "rules.patterns.codeExtensions"
        },
        "analyzeContentPatterns": {
            "signature": "async analyzeContentPatterns(files)",
            "returns": "Violation[]",
            "semantic_guarantee": "Deep examination; non-modifying",
            "settings_key": "rules.quality.enforce.*"
        },
        "createRegistrySnapshot": {
            "signature": "createRegistrySnapshot(violations)",
            "returns": "RegistrySnapshot",
            "semantic_guarantee": "State capture before write",
            "settings_key": "rules.scanning.createSnapshot"
        },
        "writeRegistryOutput": {
            "signature": "async writeRegistryOutput(snapshot)",
            "returns": "void",
            "semantic_guarantee": "Creates new entry; idempotent",
            "settings_key": null
        },
        "reportSummary": {
            "signature": "reportSummary(snapshot)",
            "returns": "void",
            "semantic_guarantee": "Side effects isolated; optional",
            "settings_key": "rules.display.*"
        }
    }

## Task 5.3: BaseValidator Verification-Gate Implementation

    DECLARE validator_spec: object

    SET validator_spec.algorithm = "Verification-Gate-Protocol"
    SET validator_spec.verb_chain = "CREATE<Invariant-Set> → ANALYZE<System-State> → ANALYZE<Violations> → EXECUTE<Halt-Or-Continue>"

    SET validator_spec.methods = {
        "createInvariantSet": {
            "signature": "async createInvariantSet()",
            "returns": "InvariantSet",
            "semantic_guarantee": "Non-deterministic creation; generates constraint candidates",
            "settings_key": "rules.strictness.*"
        },
        "analyzeSystemState": {
            "signature": "async analyzeSystemState(invariants)",
            "returns": "SystemState",
            "semantic_guarantee": "Deep examination; delegates to validation tools",
            "settings_key": null
        },
        "analyzeViolations": {
            "signature": "async analyzeViolations(state, invariants)",
            "returns": "ClassifiedViolations",
            "semantic_guarantee": "Evaluation check; validates against severity specification",
            "settings_key": "rules.severity.*"
        },
        "classifyBySeverity": {
            "signature": "classifyBySeverity(violations, invariants)",
            "returns": "{ critical, high, medium, low }",
            "semantic_guarantee": "Deterministic classification",
            "settings_key": "rules.severity.thresholds.*"
        },
        "executeValidationDecision": {
            "signature": "executeValidationDecision(violations)",
            "returns": "boolean | never (process.exit on critical)",
            "semantic_guarantee": "Side effects possible; halts on critical",
            "settings_key": "rules.severity.halt.*"
        }
    }

    VALIDATION GATE:
        ✅ auto_fixer_spec complete WITH semantic_guarantees
        ✅ scanner_spec complete WITH semantic_guarantees
        ✅ validator_spec complete WITH semantic_guarantees
        ✅ all_settings_keys mapped

# PHASE 6: Settings Schema Extension

## Task 6.1: New Settings Keys

    DECLARE new_settings_schema: object

    SET new_settings_schema = {
        "rules.tooling.autoFix": {
            "createBackups": {
                "type": "boolean",
                "default": true,
                "description": "Create backup snapshots before auto-fix modifications"
            },
            "backupLocation": {
                "type": "string",
                "default": ".claude/workspace/backups",
                "description": "Directory for storing backup snapshots"
            },
            "maxRollbackHistory": {
                "type": "number",
                "default": 10,
                "description": "Maximum number of snapshots to retain per file"
            },
            "safetyValidation": {
                "type": "boolean",
                "default": true,
                "description": "Validate fixes don't break invariants before applying"
            }
        },
        "rules.severity.halt": {
            "critical": {
                "type": "boolean",
                "default": true,
                "description": "Halt process on critical severity violations"
            },
            "high": {
                "type": "boolean",
                "default": false,
                "description": "Halt process on high severity violations"
            }
        },
        "rules.scanning": {
            "createSnapshot": {
                "type": "boolean",
                "default": true,
                "description": "Create registry snapshot before writing"
            }
        }
    }

## Task 6.2: Settings Accessor Functions

    DECLARE new_accessors: array

    SET new_accessors = [
        "getAutoFixBackupSettings(): { createBackups, backupLocation, maxRollbackHistory, safetyValidation }",
        "getSeverityHaltSettings(): { critical, high }",
        "getScannerSnapshotSettings(): { createSnapshot }"
    ]

    SET accessor_location = "root/codebase-validation/core/settings/accessors/tools/"

    VALIDATION GATE:
        ✅ new_settings_schema defined WITH types_and_defaults
        ✅ new_accessors specified WITH return_types
        ✅ backward_compatible WITH existing_settings

