---
name: codebase-validation-refactor-workflow
type: refactoring
description: Multi-agent orchestrated workflow to align codebase-validation scanners, validators, and auto-fixers with DEV-RULES-ALGORITHMS.md specifications while maintaining full settings configurability
model: sonnet
context:
    - CLAUDE.md
    - .claude/workspace/_meta-intel/algorithms/_DEV-RULES-ALGORITHMS.md
    - .claude/workspace/reports/algorithm-evaluation-report.md
---

THIS WORKFLOW refactors codebase-validation architecture to comply with algorithmic specifications using 5 specialized agents through shared document refinement

%% META %%:
intent: "Align codebase-validation with DEV-RULES-ALGORITHMS while preserving settings configurability"
objective: "Implement State-Snapshot-Recovery, Perceptual-Loop, Verification-Gate protocols in base classes"
context: "Refactoring scanners, validators, auto-fixers to explicit algorithm patterns"
priority: critical

ON ERROR file_modified:
TRY:
    RENAME current_file TO current_file.bak
    WRITE updated_content TO [NEW]current_file
    DELETE current_file.bak
    EXCEPT IF FAIL:
    RENAME current_file.bak TO current_file
END TRY

# PHASE 0: Algorithm Compliance Framework

    READ ".claude/workspace/_meta-intel/algorithms/_DEV-RULES-ALGORITHMS.md" INTO algorithm_spec
    READ ".claude/workspace/reports/algorithm-evaluation-report.md" INTO evaluation_report
    READ "root/codebase-validation/settings.json" INTO settings_config
    READ "root/codebase-validation/core/base-scanner.js" INTO base_scanner
    READ "root/codebase-validation/core/base-validator.js" INTO base_validator
    READ "root/codebase-validation/auto-fix/base-auto-fixer.js" INTO base_auto_fixer

    DECLARE algorithm_mappings: object
    SET algorithm_mappings.scanner = "Perceptual-Loop: FIND → ANALYZE → WRITE"
    SET algorithm_mappings.validator = "Verification-Gate-Protocol: CREATE → ANALYZE → ANALYZE → EXECUTE"
    SET algorithm_mappings.auto_fixer = "State-Snapshot-Recovery + Construction-Loop: EXTRACT → CREATE → ANALYZE → WRITE"

    DECLARE settings_integration: object
    SET settings_integration.principle = "All behavior configurable via settings.json"
    SET settings_integration.locations = [
        "rules.tooling.enabled.*",
        "rules.tooling.autoFix.*",
        "rules.quality.*",
        "rules.strictness.*",
        "rules.severity.*"
    ]

    VALIDATION GATE:
        ✅ algorithm_spec loaded FROM _DEV-RULES-ALGORITHMS.md
        ✅ evaluation_report loaded WITH improvement_recommendations
        ✅ settings_config loaded FOR configurability_reference
        ✅ base_classes loaded FOR refactoring_targets
        ✅ algorithm_mappings defined FOR each_component_type

# PHASE 1: Workspace Configuration

    SET artifact_base_path = ".claude/workspace/refactor-validation"
    SET workflow_name = "codebase-validation-refactor"

## Task 1.1: Define Core Documents

    DECLARE core_documents: array
    SET core_documents = [
        "ARCHITECTURAL-ASSESSMENT.md",
        "REFACTOR-PLAN.md",
        "IMPLEMENTATION-LOG.md",
        "SETTINGS-INTEGRATION.md",
        "VALIDATION-RESULTS.md",
        "WORKFLOW-STATE.md"
    ]

## Task 1.2: Document Purpose Mapping

    DECLARE document_purpose_map: object
    SET document_purpose_map["ARCHITECTURAL-ASSESSMENT.md"] = "Current state analysis, algorithm gaps, dependency graph"
    SET document_purpose_map["REFACTOR-PLAN.md"] = "Phased implementation plan with code changes"
    SET document_purpose_map["IMPLEMENTATION-LOG.md"] = "Executed changes, file modifications, test results"
    SET document_purpose_map["SETTINGS-INTEGRATION.md"] = "Settings.json schema changes, configurability map"
    SET document_purpose_map["VALIDATION-RESULTS.md"] = "Algorithm compliance verification, semantic guarantees"
    SET document_purpose_map["WORKFLOW-STATE.md"] = "Current phase, blockers, next actions"

## Task 1.3: Define Refactoring Targets

    DECLARE refactoring_targets: object

    SET refactoring_targets.critical = {
        "priority": 1,
        "component": "BaseAutoFixer",
        "file": "root/codebase-validation/auto-fix/base-auto-fixer.js",
        "algorithm": "State-Snapshot-Recovery-Protocol",
        "required_methods": [
            "extractCurrentState(file)",
            "createCheckpointSnapshot(state)",
            "analyzeStateIntegrity(fixPlan, originalState)",
            "writeWithRollback(fixedContent, snapshotId)",
            "rollbackFromSnapshot(snapshotId)"
        ],
        "settings_keys": [
            "rules.tooling.autoFix.createBackups",
            "rules.tooling.autoFix.backupLocation",
            "rules.tooling.autoFix.maxRollbackHistory"
        ]
    }

    SET refactoring_targets.high_scanner = {
        "priority": 2,
        "component": "BaseScanner",
        "file": "root/codebase-validation/core/base-scanner.js",
        "algorithm": "Perceptual-Loop",
        "required_methods": [
            "findTargetFiles()",
            "analyzeContentPatterns(files)",
            "createRegistrySnapshot(violations)",
            "writeRegistryOutput(snapshot)",
            "reportSummary(snapshot)"
        ],
        "settings_keys": [
            "rules.scanning.context.*",
            "rules.exclusions.directories.*",
            "rules.patterns.*"
        ]
    }

    SET refactoring_targets.high_validator = {
        "priority": 3,
        "component": "BaseValidator",
        "file": "root/codebase-validation/core/base-validator.js",
        "algorithm": "Verification-Gate-Protocol",
        "required_methods": [
            "createInvariantSet()",
            "analyzeSystemState(invariants)",
            "analyzeViolations(state, invariants)",
            "classifyBySeverity(violations, invariants)",
            "executeValidationDecision(violations)"
        ],
        "settings_keys": [
            "rules.severity.*",
            "rules.strictness.*",
            "rules.quality.enforce.*"
        ]
    }

    SET refactoring_targets.medium = {
        "priority": 4,
        "components": ["concrete_scanners", "concrete_validators", "concrete_fixers"],
        "count": "all_implementations",
        "algorithm": "inherit_from_base_class",
        "required_changes": [
            "Override extension points",
            "Add semantic guarantee JSDoc",
            "Map to settings keys"
        ]
    }

    VALIDATION GATE:
        ✅ core_documents defined WITH semantic_purposes
        ✅ refactoring_targets prioritized BY criticality
        ✅ algorithm_mappings linked TO targets
        ✅ settings_keys identified FOR configurability

# PHASE 2: Agent Sequence Definition

    SET agent_count = 5
    DECLARE agent_sequence: array

## Task 2.1: Agent 1 - Architecture Analyzer

    DECLARE agent_1: object
    SET agent_1.agent_name = "architecture-analyzer"
    SET agent_1.agent_type = "code-tracer-agent"
    SET agent_1.agent_phase = 1
    SET agent_1.agent_purpose = "Analyze current codebase-validation architecture and map to algorithm requirements"
    SET agent_1.agent_methodology = "CFG/AST analysis with algorithm gap detection"

    SET agent_1.focus_points = [
        "Map current BaseScanner flow to Perceptual-Loop steps",
        "Map current BaseValidator flow to Verification-Gate-Protocol steps",
        "Map current BaseAutoFixer flow to State-Snapshot-Recovery steps",
        "Identify all settings.json keys currently used",
        "Document missing extension points",
        "Create dependency graph of scanner/validator/fixer hierarchy"
    ]

    SET agent_1.output_artifacts = [
        "ARCHITECTURAL-ASSESSMENT.md: Complete gap analysis",
        "SETTINGS-INTEGRATION.md: Current settings usage map",
        "WORKFLOW-STATE.md: Phase 1 findings"
    ]

    SET agent_1.validation_gates = [
        "All base classes analyzed",
        "Algorithm gaps documented",
        "Settings usage mapped"
    ]

    APPEND agent_1 TO agent_sequence

