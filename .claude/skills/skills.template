# PHASE 3: STEP-BY-STEP PROCESS

## Process Overview

WHEN applying_this_skill:
EXECUTE skill_workflow

## STEP 1: Initial Analysis

DECLARE step_1: object
SET step_1 = {
"action": "Analyze the problem domain",
"details": [
"Identify key constraints",
"Determine applicable patterns",
"Assess complexity level"
],
"output": "Analysis results for decision making"
}

EXECUTE analysis WITH target_domain
EXTRACT constraints INTO constraint_list
IDENTIFY patterns INTO pattern_candidates

## STEP 2: Pattern Selection

DECLARE step_2: object
SET step_2 = {
"action": "Select appropriate solution pattern",
"details": [
"Match patterns to requirements",
"Evaluate trade-offs",
"Choose optimal approach"
],
"output": "Selected pattern with justification"
}

FOR EACH pattern IN pattern_candidates:
ANALYZE pattern FOR fit_score
IF fit_score > threshold:
ADD pattern TO viable_patterns

SORT viable_patterns BY fit_score DESC
SELECT viable_patterns[0] AS chosen_pattern

## STEP 3: Implementation

DECLARE step_3: object
SET step_3 = {
"action": "Apply selected pattern to problem",
"details": [
"Follow pattern structure",
"Adapt to specific context",
"Validate against requirements"
],
"output": "Implemented solution"
}

APPLY chosen_pattern TO problem_domain
VALIDATE solution AGAINST requirements
IF validation_fails:
REPORT issues
ITERATE TO STEP 2 WITH updated_constraints

