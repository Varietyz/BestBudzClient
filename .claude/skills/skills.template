# PHASE 5: COMMON PITFALLS

## Pitfall 1: Misapplying Pattern Scope

DECLARE pitfall_1: object
SET pitfall_1 = {
"description": "Applying skill beyond intended scope",
"consequence": "Incorrect or suboptimal solutions",
"avoidance": "Always verify problem matches skill domain"
}

WHEN tempted_to_over_apply:
ANALYZE problem FOR scope_match
IF problem NOT IN skill_domain:
REPORT "Out of scope for this skill"
FIND alternative_skill
ELSE:
PROCEED WITH skill_application

## Pitfall 2: Ignoring Constraints

DECLARE pitfall_2: object
SET pitfall_2 = {
"description": "Not considering important limitations",
"consequence": "Solutions that violate requirements",
"avoidance": "Always check constraints before applying patterns"
}

WHEN applying_pattern:
READ constraints FROM problem_spec
FOR EACH constraint IN constraints:
VERIFY pattern_compatibility WITH constraint
IF incompatible:
REJECT pattern
FIND compatible_alternative

## Pitfall 3: Premature Optimization

DECLARE pitfall_3: object
SET pitfall_3 = {
"description": "Applying complex patterns to simple problems",
"consequence": "Unnecessary complexity and maintenance burden",
"avoidance": "Start with simplest pattern that solves the problem"
}

WHEN choosing_pattern:
SORT patterns BY complexity ASC
FOR EACH pattern IN patterns:
IF pattern.solves(problem):
SELECT pattern
BREAK

